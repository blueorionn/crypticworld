{
    "builds": [
        {
            "src": "wsgi.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "wsgi.py"
        }
    ],
    "env": {
        "FLASK_ENV": "production"
    },
    "framework": "custom",
    "github": {
        "command": "gunicorn wsgi:application --bind 0.0.0.0:5000"
    }
}