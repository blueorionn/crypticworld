{
  "name": "crypticworld",
  "version": "1.0.0",
  "description": "Crypticworld is a lightweight web application built using Flask that allows users to hash any given text using a wide variety of hashing algorithms.",
  "main": "index.js",
  "private": "true",
  "scripts": {
    "watchCss": "npx tailwindcss -i ./crypticworld/static/css/tailwind.css -o ./crypticworld/static/css/style.css --watch",
    "buildCss": "npx tailwindcss -i ./crypticworld/static/css/tailwind.css -o ./crypticworld/static/css/style.css --minify",
    "format": "prettier --write \"**/*.{html,css,js}\"",
    "format:check": "prettier --check \"**/*.{html,css,js}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueorionn/crypticworld.git"
  },
  "author": "Swadhin",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
